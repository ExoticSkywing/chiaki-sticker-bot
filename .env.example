# Copy this file to .env and fill in real values before starting Docker Compose.
# The existing .gitignore excludes .env, so secrets stay local.

# ---- Required Telegram settings ----
BOT_TOKEN=123456789:replace-me

# Public HTTPS URLs served by your host Nginx.
# WEBHOOK_URL must end with /webhook.
# WEBAPP_URL must end with /webapp to enable the full WebApp features.
WEBHOOK_URL=https://bot.example.com/webhook
WEBAPP_URL=https://bot.example.com/webapp

# Generate one with: openssl rand -hex 32
WEBHOOK_SECRET=replace-with-random-hex

# Your Telegram numeric user ID. Used for admin-only manage features.
# Leave as -1 to disable admin privileges.
ADMIN_UID=-1

# ---- External MySQL / MariaDB / TiDB settings ----
# Required for /search and usage tracking. Leave empty to disable DB features.
DB_ADDR=127.0.0.1:3306
DB_USER=stickerbot
DB_NAME=stickerbot
DB_PASS=replace-me
# Use false for a local/BT MySQL without a valid TLS certificate.
# Use true for TiDB Cloud or MySQL services with valid TLS.
DB_TLS_CONFIG=false

# ---- Host/container settings ----
# With network_mode: host, the container's internal nginx listens on this host port.
HOST_PORT=18080
LOG_LEVEL=info

# ---- Performance tuning for this server: 2 vCPU / ~11 GiB RAM ----
GOMEMLIMIT=6GiB
MSB_IMPORT_CONCURRENCY=3
MSB_FFMPEG_CONCURRENCY=2
MSB_WEBM_WORKER_CONCURRENCY=2
MSB_IM_MEMORY_LIMIT=1GiB
MSB_IM_MAP_LIMIT=2GiB
MSB_IM_OOM_MEMORY_LIMIT=512MiB
MSB_IM_OOM_MAP_LIMIT=1GiB
MSB_KAKAO_FAST_PIPE=1
MSB_CONVERT_TIMEOUT_SECONDS=240
MSB_IMPORT_QUEUE_TIMEOUT_SECONDS=1800

# Optional DB maintenance tuning.
# MSB_DB_CURATION_BATCH_SIZE=500
